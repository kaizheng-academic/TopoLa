function [Matrix] = DRN(R_Omega)
    E=0.8;
    tic
    [U,S,V] = svdsketch(R_Omega,0.1);
    toc
    
    
    
    tic
    S_=diag(S);
    energy=0
    for i=1:length(S_)
        energy=energy+S_(i)/sum(S_);
        if energy>E
            lambda=S_(i)*S_(i);
            break
        end
    end
    
    for i=1:length(S_)
         if S_(i)~=0   
            S_(i)=S_(i)^3/(S_(i)^2+lambda);
         end
    end
    S(logical(eye(size(S))))=S_;
    
    Matrix=U*S*V';
    toc
    end
    